# ========================================
# AZAHEL NEMOTRON - KPKAVE v2.5 CONFIG
# ========================================

# CLOUDFLARE WORKER (REQUERIDO)
# URL de tu Edge Function en Cloudflare
# Formato: https://tu-dominio.com/api/v1/process
CLOUDFLARE_WORKER_URL=https://your-worker.your-domain.com/api/v1/process

# CLOUDFLARE API (Opcional - solo si usas wrangler CLI)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# NVIDIA NEMOTRON API (OPCIONAL - para cloud inference con LLM)
NVIDIA_API_KEY=your_nvidia_api_key_here
NEMOTRON_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# LOCAL MODEL LLAMA.CPP (OPCIONAL - para offline mode)
LLAMA_MODEL_PATH=~/storage/shared/Azael_KpKave/modelos/azael-kpkave-q4.gguf
LLAMA_CPP_PATH=~/llama.cpp/main

# PYTORCH PROCESSING CONFIG
PYTORCH_MATRIX_SIZE=1000
PYTORCH_BATCH_SIZE=1000
PROCESS_TIMEOUT=60
RETRY_ATTEMPTS=3

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=./logs/azahel.log

# SECURITY & CORS
ENABLE_SSL_VERIFY=true
CORS_ALLOWED_ORIGINS=*
