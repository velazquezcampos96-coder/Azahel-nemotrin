# CLOUDFLARE CONFIGURATION
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_WORKER_URL=https://your-worker.your-domain.com/api/v1/process

# NVIDIA NEMOTRON API (OPTIONAL - for cloud inference)
NVIDIA_API_KEY=your_nvidia_api_key_here
NEMOTRON_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# LOCAL MODEL (if using .gguf)
LLAMA_MODEL_PATH=~/storage/shared/Azael_KpKave/modelos/azael-kpkave-q4.gguf
LLAMA_CPP_PATH=~/llama.cpp/main

# PROCESSING CONFIG
PYTORCH_BATCH_SIZE=1000
PYTORCH_MATRIX_SIZE=1000
PROCESS_TIMEOUT=60
RETRY_ATTEMPTS=3

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=./logs/azahel.log

# SECURITY
ENABLE_SSL_VERIFY=true
CORS_ALLOWED_ORIGINS=*
